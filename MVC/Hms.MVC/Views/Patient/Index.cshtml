@model IEnumerable<Hms.MVC.Models.Patient.PatientViewModel>

@{
    ViewData["Title"] = "Patients";
}

<div class="page-header">
    <div>
        <h1>Patients</h1>
        <p>Manage hospital patients and their records.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add Patient
    </a>
</div>

<div class="table-container animate-fade-in-up">
    <div class="table-header">
        <h3 class="table-title">Patient List</h3>
    </div>
    <div class="card-body" style="padding: var(--space-lg);">
        <table id="patientsTable" class="hms-table w-100">
            <thead>
                <tr>
                    <th>SSN</th>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Phone</th>
                    @if ((Context.Session.GetString("UserRole") ?? string.Empty) == "admin")
                    {
                        <th>Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="badge badge-teal">@Html.DisplayFor(modelItem => item.Ssn)</span>
                        </td>
                        <td style="font-weight: 500; color: var(--text-primary);">
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Address)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Phone)
                        </td>
                        @if ((Context.Session.GetString("UserRole") ?? string.Empty) == "admin")
                        {
                            <td>
                                <div class="d-flex gap-2">
                                    <form asp-action="Delete" asp-route-id="@item.Ssn" method="post" class="delete-form">

                                        <button type="submit" class="btn btn-sm btn-danger delete-btn">Delete</button>
                                    </form>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <!-- Include DataTables CSS/JS here if not already in Layout -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" />
    
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            // Initialize DataTable
            $('#patientsTable').DataTable({
                responsive: true,
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Search patients..."
                },
                @if ((Context.Session.GetString("UserRole") ?? string.Empty) == "admin")
                {
                    @:columnDefs: [
                    @:{ orderable: false, targets: 4 }
                    @:],
                }
                // Styling hooks to match our dark theme
                drawCallback: function () {
                    $('.dataTables_paginate > .pagination').addClass('pagination-sm');
                }
            });

            // SweetAlert2 for Delete Confirmation
            $('.delete-form').on('submit', function (e) {
                e.preventDefault();
                var form = this;

                Swal.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Yes, delete it!',
                    background: 'var(--bg-card)',
                    color: 'var(--text-primary)'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
    
    <style>
        /* Minimal custom styling for DataTables to match our theme */
        .dataTables_wrapper .dataTables_length, .dataTables_wrapper .dataTables_filter, .dataTables_wrapper .dataTables_info, .dataTables_wrapper .dataTables_processing, .dataTables_wrapper .dataTables_paginate {
            color: var(--text-secondary);
            margin-bottom: var(--space-md);
        }
        .dataTables_wrapper .dataTables_filter input {
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            border-radius: var(--radius-sm);
            padding: 4px 8px;
        }
        .dataTables_wrapper .dataTables_length select {
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            border-radius: var(--radius-sm);
            padding: 4px 8px;
        }
        .page-item.disabled .page-link {
            background-color: var(--bg-card);
            border-color: var(--border-color);
            color: var(--text-muted);
        }
        .page-item .page-link {
            background-color: var(--bg-card);
            border-color: var(--border-color);
            color: var(--text-primary);
        }
        .page-item.active .page-link {
            background-color: var(--accent-teal);
            border-color: var(--accent-teal);
        }
    </style>
}

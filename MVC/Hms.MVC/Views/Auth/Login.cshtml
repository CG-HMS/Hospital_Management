@model Hms.MVC.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-page">
    <div class="login-theme-toggle">
        <button class="theme-toggle" aria-label="Toggle theme">🌙</button>
    </div>

    <div class="login-card">
        <div class="login-brand">
            <div class="login-logo">🏥</div>
            <h1><span>HMS</span> Portal</h1>
            <p>Hospital Management System</p>
        </div>

        @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
        {
            <div class="alert alert-danger animate-fade-in">
                ⚠️ @Model.ErrorMessage
            </div>
        }

        <form class="login-form" method="post" asp-action="Login" asp-controller="Auth">
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="form-group">
                <label class="form-label" for="Email">Email Address</label>
                <input class="form-control" asp-for="Email" id="Email"
                       type="email" placeholder="admin@hms.com" autocomplete="email" autofocus />
                <span asp-validation-for="Email" class="form-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="Password">Password</label>
                <input class="form-control" asp-for="Password" id="Password"
                       type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="form-error"></span>
            </div>

            <button type="submit" class="login-btn" id="loginBtn">
                Sign In
            </button>
        </form>

        <div class="login-footer">
            <p>© 2026 Hospital Management System</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('.login-form')?.addEventListener('submit', function () {
            const btn = document.getElementById('loginBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner" style="width:20px;height:20px;border-width:2px;display:inline-block;vertical-align:middle;margin-right:8px;"></span> Signing in...';
        });
    </script>
}
